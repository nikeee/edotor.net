{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [],
  "categories": {
    "correctness": "off"
  },
  "env": {
    "builtin": true
  },
  "jsPlugins": [{ "name": "react-hooks-js", "specifier": "eslint-plugin-react-hooks" }],
  "ignorePatterns": ["dist/", "node_modules/"],
  "overrides": [
    {
      "files": ["*/**/*.{js,ts,tsx,jsx}"],
      "plugins": ["react"]
    }
  ]
}
